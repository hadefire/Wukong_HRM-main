<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kakarote.hrm.mapper.AdminUserRoleMapper">

    <select id="queryRoleIdsByUserId" resultType="java.lang.Long">
        SELECT role_id FROM wk_admin_user_role WHERE user_id = #{userId}
    </select>

    <select id="queryUserIdsByRoleType" resultType="java.lang.Long">
        SELECT DISTINCT ur.user_id
        FROM wk_admin_user_role ur
        INNER JOIN wk_admin_role r ON ur.role_id = r.role_id
        WHERE r.role_type = #{roleType}
    </select>

    <delete id="deleteByUserId">
        DELETE FROM wk_admin_user_role WHERE user_id = #{userId}
    </delete>

</mapper>
